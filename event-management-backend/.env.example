# Server
PORT=5000
NODE_ENV=production

# MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.v4grugl.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI_LOCAL=mongodb://127.0.0.1:27017/eventhub

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=7d

# CORS
CLIENT_URL=https://your-frontend.netlify.app

# Rate limiting
RATE_LIMIT_WINDOW_MS=15*60*1000
RATE_LIMIT_MAX=100

# Optional Redis (for caching)
REDIS_URL=redis://localhost:6379